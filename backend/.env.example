# ───────────────────────────────────────────────────────
# TrackFit Ultra Production Environment Configuration
# Copy this file to .env and fill in your values
# ───────────────────────────────────────────────────────

# Environment
ENVIRONMENT=production
DEBUG=false

# Database - Use PostgreSQL in production!
# DATABASE_URL=postgresql://username:password@hostname:port/database_name
DATABASE_URL=sqlite:///./trackfit.db

# Security - CHANGE THESE IN PRODUCTION!
JWT_SECRET=your-very-long-random-secret-key-here-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS Configuration - Restrict this to your actual domains in production
CORS_ORIGINS=*

# External APIs
OPENROUTER_API_KEY=your_openrouter_api_key_here
API_NINJAS_KEY=your_api_ninjas_key_here
HF_TOKEN=your_huggingface_token_here

# Logging
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60